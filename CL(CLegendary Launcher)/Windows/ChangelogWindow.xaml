<ui:FluentWindow x:Class="CL_CLegendary_Launcher_.Windows.ChangelogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
                 Title="ChangeLogMinecraft" Height="600" Width="800"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica" Background="{DynamicResource MainBackgroundBrush}" Foreground="{DynamicResource MainForegroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="ChangeLog Minecraft" Foreground="{DynamicResource MainForegroundBrush}" />

        <Grid Grid.Row="1" Margin="20">
            <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Margin="0,0,0,15" Width="40" Height="40" Foreground="{DynamicResource MainForegroundBrush}" CoverRingStroke="{DynamicResource MainBackgroundProgressBar}"/>
                <TextBlock x:Name="LoadingText" Text="Шукаю новини..." FontSize="16" HorizontalAlignment="Center" TextAlignment="Center" FontFamily="Inter 18pt 18pt"/>
            </StackPanel>

            <markdig:MarkdownViewer x:Name="ChangelogMarkdownViewer" Margin="10,0,20,20" FontFamily="Inter 18pt 18pt">
                <markdig:MarkdownViewer.Resources>
                    <ResourceDictionary>
                        <ResourceDictionary.MergedDictionaries>
                            <ResourceDictionary Source="/Them/DarkTheme.xaml" />
                        </ResourceDictionary.MergedDictionaries>

                        <Style TargetType="{x:Type FlowDocument}">
                            <Setter Property="Foreground" Value="{DynamicResource MainForegroundBrush}" />
                            <Setter Property="FontFamily" Value="Impact" />
                        </Style>

                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Foreground" Value="{DynamicResource MainForegroundBrush}" />
                        </Style>
                        <Style TargetType="{x:Type Run}">
                            <Setter Property="Foreground" Value="{DynamicResource MainForegroundBrush}" />
                        </Style>
                    </ResourceDictionary>
                </markdig:MarkdownViewer.Resources>
            </markdig:MarkdownViewer>
            <StackPanel x:Name="WikiFallbackPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock x:Name="WikiFallbackText" 
                           Text="Ця версія занадто стара..." 
                           FontSize="16" TextAlignment="Center" Foreground="{DynamicResource MainForegroundBrush}" Margin="0,0,0,20"/>
                <ui:Button x:Name="OpenWikiButton" Content="Читати на Minecraft Wiki" Icon="Book24" Appearance="Primary" HorizontalAlignment="Center" Click="OpenWikiButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>