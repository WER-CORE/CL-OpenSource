<Window x:Class="CL_CLegendary_Launcher_.Windows.EulaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Угода" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">

    <Grid>
        <Border CornerRadius="20" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>

            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtMascotName" 
                           Text="Сіель" 
                           Foreground="{DynamicResource MainForegroundBrush}" 
                           FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>

                    <TextBlock x:Name="TxtMascotRole" 
                           Text="Головний адміністратор" 
                           Foreground="Gray" 
                           FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2B2B2B" CornerRadius="0,15,15,15" Margin="0,0,0,15" Padding="15">
                        <TextBlock x:Name="MascotMessageText" 
                               Text="Привіт! Тут мають бути важливі правила..." 
                               Foreground="{DynamicResource MainForegroundBrush}" TextWrapping="Wrap" FontSize="15"/>
                    </Border>

                    <Border Grid.Row="1" Background="#222222" CornerRadius="10" BorderBrush="#333333" BorderThickness="1">
                        <ui:DynamicScrollViewer Margin="10,10,-1,10">
                            <TextBlock x:Name="EulaContentText" 
                                   Foreground="{DynamicResource MainForegroundBrush}" FontSize="13" TextWrapping="Wrap" 
                                   FontFamily="Consolas, Segoe UI" Width="503"/>
                        </ui:DynamicScrollViewer>
                    </Border>

                    <Border Grid.Row="2" Background="#2B2B2B" CornerRadius="8" Margin="0,15,0,0" Padding="10,8">
                        <CheckBox x:Name="ChkAllowCrashReports" IsChecked="True" Cursor="Hand" Background="{DynamicResource MainBackgroundButton}" BorderBrush="{x:Null}" Foreground="{DynamicResource MainForegroundBrush}">
                            <TextBlock Foreground="{DynamicResource MainForegroundBrush}" TextWrapping="Wrap">
                            <Run x:Name="RunCrashTitle" FontWeight="SemiBold" Text="Дозволити анонімну відправку звітів про помилки."/>
                             <LineBreak/>
                             <Run x:Name="RunCrashDesc" FontSize="11" Foreground="Gray" Text="Це допоможе нам швидше виправляти баги. Жодні особисті дані не збираються."/>
                            </TextBlock>
                        </CheckBox>
                    </Border>

                    <Grid Grid.Row="3" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" x:Name="LanguageComboBox" 
                              Width="160" Height="40" 
                              SelectionChanged="LanguageComboBox_SelectionChanged"
                              Background="#2B2B2B" Foreground="{DynamicResource MainForegroundBrush}" BorderBrush="#333333" Cursor="Hand">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <Border CornerRadius="3" ClipToBounds="True" Width="24" Height="16" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Image Source="{Binding FlagUrl}" Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center" Foreground="White"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button x:Name="BtnDecline" Content="Я не згоден (Вихід)" Height="40" Padding="20,0"
                                   Background="Transparent" Foreground="#FF5555" BorderThickness="0"
                                   Cursor="Hand" Click="Decline_Click" FontWeight="SemiBold" Margin="0,0,15,0"/>

                            <ui:Button x:Name="BtnAccept" Content="Згода!" Height="40" Padding="30,0"
                                   Background="#FF1843C9" Foreground="White" BorderThickness="0"
                                   Cursor="Hand" Click="Accept_Click" FontWeight="Bold" BorderBrush="{x:Null}">
                                <ui:Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </ui:Button.Resources>
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>