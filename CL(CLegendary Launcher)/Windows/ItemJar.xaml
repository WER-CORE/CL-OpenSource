<UserControl x:Name="UserControl" x:Class="CL_CLegendary_Launcher_.Windows.ItemJar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CL_CLegendary_Launcher_.Windows"
             mc:Ignorable="d" 
             Height="108" Width="740">

    <Grid x:Name="GirdMain">
        <Border x:Name="Border" BorderThickness="1" Background="{DynamicResource MainBackgroundBrushServer}" CornerRadius="15">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" x:Name="BorderImage" BorderThickness="1" 
                        Height="86" Width="86" 
                        Background="{DynamicResource MainBackgroundBrush}" CornerRadius="6"
                        ClipToBounds="True">
                    <Image x:Name="ModIcon" RenderOptions.BitmapScalingMode="LowQuality" Stretch="UniformToFill"/>
                </Border>

                <Grid Grid.Column="1" Margin="15,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="Title" Text="Mod Name" 
                               FontFamily="Inter" FontWeight="Bold" FontSize="20" 
                               Foreground="{DynamicResource MainForegroundBrush}" 
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Grid.Row="1" x:Name="Description" 
                               Text="Long description of the mod goes here..." 
                               FontFamily="Inter" FontSize="12" Foreground="Gray" 
                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis" 
                               Margin="0,5,0,5" Opacity="0.8"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">

                        <StackPanel x:Name="ToolTipDownloads" Orientation="Horizontal" Margin="0,0,15,0" ToolTip="Кількість завантажень">
                            <Path Data="M19,9h-4V3H9v6H5l7,7l7-7z M5,18v2h14v-2H5z" 
                                  Fill="{DynamicResource MainForegroundBrush}" 
                                  Stretch="Uniform" Width="14" Height="14" Margin="0,0,5,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock x:Name="DowloadCountTXT" Text="0" FontFamily="Inter" FontSize="11" Foreground="{DynamicResource MainForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel x:Name="ToolTipUpdate" Orientation="Horizontal" Margin="0,0,15,0" ToolTip="Останнє оновлення">
                            <Path Data="M12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm0-14c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6z M11 7h2v5.4l3.5 2.1-1 1.7-4.5-2.7V7z" 
                                  Fill="{DynamicResource MainForegroundBrush}" 
                                  Stretch="Uniform" Width="14" Height="14" Margin="0,0,5,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock x:Name="DataUpdateLastTXT" Text="Date" FontFamily="Inter" FontSize="11" Foreground="{DynamicResource MainForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel x:Name="ToolTipAuthor" Orientation="Horizontal" ToolTip="Автор">
                            <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                                  Fill="{DynamicResource MainForegroundBrush}" 
                                  Stretch="Uniform" Width="14" Height="14" Margin="0,0,5,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock x:Name="User_AuthorTXT" Text="Author" FontFamily="Inter" FontSize="11" Foreground="{DynamicResource MainForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,0,0">

                    <Border x:Name="DowloadMod" 
                            Height="30" Width="100" 
                            CornerRadius="6" Cursor="Hand" Margin="0,0,0,8" Background="{DynamicResource MainBackgroundButton}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" 
                                  Fill="{DynamicResource MainForegroundBrush}" 
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock x:Name="DowloadTXT" Text="Встановити" 
                                       Foreground="{DynamicResource MainForegroundBrush}" 
                                       FontFamily="Inter" FontWeight="Bold" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DetailsMod" 
                            Height="30" Width="100" 
                            CornerRadius="6" Cursor="Hand" BorderThickness="1" Background="{DynamicResource MainBackgroundButton}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z" 
                                  Fill="{DynamicResource MainForegroundBrush}" 
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,5,0"
                                  Opacity="0.9" VerticalAlignment="Center"/>
                            <TextBlock x:Name="DetailsTXT" Text="Докладніше" 
                                       Foreground="{DynamicResource MainForegroundBrush}" 
                                       FontFamily="Inter" FontWeight="SemiBold" FontSize="11" Opacity="0.9"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>