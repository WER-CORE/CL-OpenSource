<Window x:Class="CL_CLegendary_Launcher_.Windows.CreditsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Подяки" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">

    <Grid>
        <Border CornerRadius="20" Background="{DynamicResource MainBackgroundBrush}" BorderBrush="{DynamicResource MainBackgroundBrushServer}" BorderThickness="1" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>

            <Grid Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" x:Name="MascotColumn"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" x:Name="MascotPanel" VerticalAlignment="Center">
                    <Image Height="200" 
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="pack://application:,,,/Assets/Ciel_Happy.png"/>
                    <TextBlock x:Name="CreditsTitleTxt" Text="Автори та Спільнота" Foreground="{DynamicResource MainForegroundBrush}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,15,0,5" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource MainBackgroundBrushServer}" CornerRadius="10" BorderThickness="0" Padding="15">
                        <ui:DynamicScrollViewer>
                            <Grid>
                                <ui:ProgressRing x:Name="LoadingRing" IsIndeterminate="True" Width="40" Height="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <TextBlock x:Name="CreditsContentText" 
                                           Text="Сіель шукає список наших героїв..."
                                           Foreground="{DynamicResource MainForegroundBrush}" 
                                           FontSize="15" TextWrapping="Wrap" 
                                           FontFamily="Inter, Consolas, Segoe UI"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                        </ui:DynamicScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <ui:Button x:Name="BtnClose" Content="Закрити" Height="40" Padding="30,0"
                                   Background="{DynamicResource MainBackgroundProgressBar}" 
                                   Foreground="{DynamicResource MainForegroundBrush}" BorderThickness="0"
                                   Cursor="Hand" Click="BtnClose_Click" FontWeight="Bold">
                            <ui:Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </ui:Button.Resources>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>